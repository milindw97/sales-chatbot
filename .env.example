# LLM Configuration
# Choose: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Gemini API Key (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (only needed if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Configuration
# Choose: "sentence-transformers" or "gemini"
EMBEDDING_PROVIDER=sentence-transformers

# Sentence Transformers Model
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Database Configuration
DB_PATH=data/db/sales_calls.db
FAISS_INDEX_PATH=data/db/faiss_index

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
